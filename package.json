{
  "name": "batchviproc",
  "version": "1.1.0",
  "description": "Electron app for batch video processing",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check app/main.js && node --check app/preload.js && node --check app/renderer.js",
    "dist": "electron-builder --publish never",
    "release": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.kachurovskiy.batchviproc",
    "productName": "batchviproc",
    "artifactName": "${productName}-${version}-portable.${ext}",
    "win": {
      "target": "portable",
      "icon": "app/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kachurovskiy",
        "repo": "batchviproc",
        "releaseType": "release"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kachurovskiy/batchviproc.git"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kachurovskiy/batchviproc/issues"
  },
  "homepage": "https://github.com/kachurovskiy/batchviproc#readme",
  "dependencies": {
    "ffmpeg-static": "5.2.0",
    "glob": "11.0.0",
    "utimes": "5.2.1"
  },
  "devDependencies": {
    "electron": "31.3.1",
    "electron-builder": "24.13.3"
  }
}
